{
  "name": "nuveon-time-keeper",
  "displayName": "Nuveon Time Keeper",
  "description": "Low-friction time tracking for Cursor and VS Code.",
  "version": "0.0.30",
  "publisher": "NuveonConsultingPTYLTD",
  "license": "UNLICENSED",
  "icon": "media/logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/nuveon/time-keeper.git",
    "directory": "packages/extension"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:timeKeeper.startTask",
    "onCommand:timeKeeper.stopTask",
    "onCommand:timeKeeper.switchTask",
    "onCommand:timeKeeper.resumePrevious",
    "onCommand:timeKeeper.statusBarClick",
    "onCommand:timeKeeper.openSummary",
    "onCommand:timeKeeper.buildTimesheetText",
    "onCommand:timeKeeper.setupMcp"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "timeKeeper.openSummary",
        "title": "Nuveon Time Keeper: Open summary",
        "icon": "$(table)"
      },
      {
        "command": "timeKeeper.buildTimesheetText",
        "title": "Nuveon Time Keeper: Build timesheet text…",
        "icon": "$(file-text)"
      },
      {
        "command": "timeKeeper.setupMcp",
        "title": "Nuveon Time Keeper: Set up MCP (VS Code or Cursor)…",
        "icon": "$(server-process)"
      },
      {
        "command": "timeKeeper.startTask",
        "title": "Nuveon Time Keeper: Start…"
      },
      {
        "command": "timeKeeper.stopTask",
        "title": "Nuveon Time Keeper: Stop"
      },
      {
        "command": "timeKeeper.switchTask",
        "title": "Nuveon Time Keeper: Switch…"
      },
      {
        "command": "timeKeeper.resumePrevious",
        "title": "Nuveon Time Keeper: Resume previous"
      },
      {
        "command": "timeKeeper.statusBarClick",
        "title": "Nuveon Time Keeper: Status bar menu"
      }
    ],
    "keybindings": [
      {
        "command": "timeKeeper.startTask",
        "key": "ctrl+shift+;",
        "mac": "cmd+shift+;"
      },
      {
        "command": "timeKeeper.stopTask",
        "key": "ctrl+shift+'",
        "mac": "cmd+shift+'"
      },
      {
        "command": "timeKeeper.resumePrevious",
        "key": "ctrl+shift+,",
        "mac": "cmd+shift+,"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.1",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  }
}
